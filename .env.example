# Tourism Agent - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ==================== Application ====================
VERSION=2.0.0
APP_NAME=Tourism Agent
DEBUG=false

# ==================== LLM Configuration ====================
# Primary LLM Provider (openrouter/openai/anthropic/local/siliconflow/zhipu)
LLM_PROVIDER=openrouter
LLM_MODEL=qwen/qwen3-30b-a3b:free
LLM_API_KEY=your_openrouter_api_key_here
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
LLM_MAX_TOKENS=4096

# Backup LLM (if primary fails)
BACKUP_LLM_PROVIDER=openai
BACKUP_LLM_MODEL=gpt-4o-mini
BACKUP_LLM_API_KEY=your_backup_api_key_here

# SiliconFlow (Alternative cheap LLM)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# Zhipu AI (GLM)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==================== Gaode Maps (AMap) ====================
# Required for POI search, weather, and routing
AMAP_API_KEY=your_amap_api_key_here
AMAP_SECURITY_CODE=

# ==================== Database Configuration ====================
# PostgreSQL (Async - for FastAPI)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tourism_agent
# PostgreSQL (Sync - for CLI tools)
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/tourism_agent

# ==================== Redis Configuration ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== Vector Database Configuration ====================
# Supported: qdrant, milvus, chroma
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=6333
VECTOR_DB_API_KEY=
VECTOR_DB_COLLECTION_NAME=poi_embeddings
VECTOR_DB_DIMENSION=1536

# ==================== Server Configuration ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=false
SERVER_WORKERS=1
SERVER_RELOAD=false

# ==================== Feature Flags ====================
ENABLE_STREAMING=true
ENABLE_CACHING=true
ENABLE_METRICS=true
ENABLE_TRACING=false
TRACE_OUTPUT_DIR=experiments/results/traces

# ==================== Rate Limiting ====================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# ==================== Frontend ====================
FRONTEND_URL=http://localhost:3000

# ==================== Session ====================
MAX_SESSION_HISTORY=50
